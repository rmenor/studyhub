# ─── Database ────────────────────────────────────────────────────────
# Postgres connection (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://studyhub:studyhub@localhost:5432/studyhub?schema=public"

# ─── Auth.js v5 ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-32-byte-base64-string"
# Optional, only if behind a reverse proxy with HTTPS
# AUTH_URL="https://studyhub.example.com"

# ─── App config ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="StudyHub"
NODE_ENV="development"

# ─── Supabase ────────────────────────────────────────────────────────
# Used by the @supabase/supabase-js client (storage, optional features).
# Required by src/lib/supabase.ts. Leave unset if you don't use Supabase.
# The NEXT_PUBLIC_ prefix is required for these to be readable in the browser.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# Optional — server-only. Admin key (NEVER expose to the browser, do NOT
# prefix with NEXT_PUBLIC_). Used to bypass RLS for trusted server-side
# operations. Get it from Supabase → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=""